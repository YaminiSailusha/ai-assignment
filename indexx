<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Usharamadmart • Simple Store</title>
  <style>
    :root{
      --red:#e11d48; /* rose-600 */
      --blue:#2563eb; /* blue-600 */
      --black:#0b0f19;
      --white:#ffffff;
      --gray:#f3f4f6;
      --muted:#6b7280;
      --radius:16px;
    }
    *{box-sizing:border-box}
    html,body{margin:0;padding:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Ubuntu,Helvetica,Arial,sans-serif;background:var(--gray);color:var(--black)}
    a{color:inherit;text-decoration:none}
    .container{max-width:1100px;margin:0 auto;padding:16px}

    /* Header */
    header{position:sticky;top:0;z-index:50;background:var(--white);border-bottom:1px solid #e5e7eb}
    .nav{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:12px 16px}
    .brand{display:flex;align-items:center;gap:10px}
    .logo{width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,var(--red),var(--blue));display:grid;place-items:center;color:#fff;font-weight:800}
    .brand h1{font-size:18px;margin:0}
    .menu{display:flex;gap:12px;flex-wrap:wrap}
    .btn{display:inline-flex;align-items:center;gap:8px;padding:10px 14px;border-radius:var(--radius);border:1px solid #e5e7eb;background:var(--white);cursor:pointer;font-weight:600}
    .btn:hover{transform:translateY(-1px);box-shadow:0 6px 18px rgba(0,0,0,.06)}
    .btn.primary{background:linear-gradient(135deg,var(--red),var(--blue));border:none;color:var(--white)}
    .pill{background:#eef2ff;color:#1e40af;padding:6px 10px;border-radius:999px;font-size:12px;font-weight:700}

    /* Layout / cards */
    .grid{display:grid;gap:16px}
    .grid.products{grid-template-columns:repeat(auto-fill,minmax(220px,1fr))}
    .card{background:var(--white);border:1px solid #e5e7eb;border-radius:var(--radius);overflow:hidden}
    .card .body{padding:12px 14px}
    .price{font-weight:800}
    .muted{color:var(--muted);font-size:14px}
    .badge{display:inline-block;padding:4px 8px;border-radius:999px;border:1px solid #e5e7eb;font-size:12px}
    .row{display:flex;align-items:center;gap:12px}
    .space-between{display:flex;align-items:center;justify-content:space-between}

    /* Sections */
    section{display:none;padding:18px 0}
    section.active{display:block}

    /* Forms */
    input,select{width:100%;padding:10px 12px;border:1px solid #e5e7eb;border-radius:12px;background:#fff}
    label{font-size:14px;color:var(--muted)}
    form{display:grid;gap:12px}

    /* Tables */
    table{width:100%;border-collapse:collapse;background:#fff;border:1px solid #e5e7eb;border-radius:12px;overflow:hidden}
    th,td{padding:12px;border-bottom:1px solid #f1f5f9;text-align:left}
    tfoot td{font-weight:800}

    /* Footer */
    footer{margin-top:40px;padding:24px 16px;text-align:center;color:var(--muted)}

    .hidden{display:none !important}
    .chip{padding:6px 10px;border-radius:999px;background:#fee2e2;color:#7f1d1d;font-weight:700;font-size:12px}
    .right{margin-left:auto}
    .img{aspect-ratio:4/3;width:100%;background:#111;background-image:linear-gradient(135deg, rgba(255,255,255,.1) 25%, transparent 25%),linear-gradient(225deg, rgba(255,255,255,.1) 25%, transparent 25%),linear-gradient(45deg, rgba(255,255,255,.1) 25%, transparent 25%),linear-gradient(315deg, rgba(255,255,255,.1) 25%, rgba(255,255,255,.1) 25%);
      background-position:10px 0,10px 0,0 0,0 0;background-size:10px 10px;background-repeat:repeat;display:grid;place-items:center;color:#fff;font-weight:800}
    .img.red{background-color:var(--red)}
    .img.blue{background-color:var(--blue)}
    .img.black{background-color:#111827}
    .img.white{background-color:#e5e7eb;color:#111}
    .qty{width:72px}
  </style>
</head>
<body>
  <header>
    <div class="nav container">
      <div class="brand">
        <div class="logo">UM</div>
        <h1>Usharamadmart</h1>
        <span class="pill" id="rolePill">Guest</span>
      </div>
      <nav class="menu">
        <a href="#shop" class="btn">Shop</a>
        <a href="#cart" class="btn">Cart <span id="cartCount" class="badge">0</span></a>
        <a href="#admin" id="adminLink" class="btn hidden">Admin</a>
        <a href="#login" id="loginLink" class="btn primary">Login</a>
        <button id="logoutBtn" class="btn hidden">Logout</button>
      </nav>
    </div>
  </header>

  <main class="container">
    <!-- LOGIN -->
    <section id="login" class="active">
      <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(280px,1fr))">
        <div class="card">
          <div class="img blue">LOGIN</div>
          <div class="body">
            <h2 style="margin:6px 0">Sign in</h2>
            <p class="muted" style="margin-top:0">Demo credentials: <b>User</b> (user / user123) • <b>Admin</b> (admin / admin123)</p>
            <form id="loginForm">
              <div>
                <label>Username</label>
                <input required name="username" placeholder="Enter username" />
              </div>
              <div>
                <label>Password</label>
                <input required type="password" name="password" placeholder="Enter password" />
              </div>
              <div>
                <label>Role</label>
                <select name="role">
                  <option value="user">User</option>
                  <option value="admin">Admin</option>
                </select>
              </div>
              <button class="btn primary" type="submit">Login</button>
            </form>
          </div>
        </div>
        <div class="card">
          <div class="img red">ABOUT</div>
          <div class="body">
            <h2 style="margin:6px 0">Welcome to Usharamadmart</h2>
            <p class="muted">A simple sample e‑commerce site built using only HTML, CSS, and JavaScript. Colours: <b style="color:var(--red)">Red</b>, <b style="color:var(--blue)">Blue</b>, <b style="color:#111">Black</b>, and <b>White</b>.</p>
            <ul class="muted">
              <li>Browse products and add to cart</li>
              <li>Cart calculates totals in ₹ (Indian Rupees)</li>
              <li>Login as <b>User</b> or <b>Admin</b></li>
              <li>Admin can add/remove products</li>
              <li>Everything is saved in your browser (localStorage)</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- SHOP -->
    <section id="shop">
      <div class="space-between" style="margin-bottom:12px">
        <h2>Products</h2>
        <div class="row">
          <input id="searchBox" placeholder="Search products…" />
          <select id="sortBox">
            <option value="popular">Sort: Popular</option>
            <option value="priceAsc">Price: Low → High</option>
            <option value="priceDesc">Price: High → Low</option>
            <option value="name">Name A → Z</option>
          </select>
        </div>
      </div>
      <div id="productGrid" class="grid products"></div>
    </section>

    <!-- CART -->
    <section id="cart">
      <h2>Your Cart</h2>
      <div id="cartEmpty" class="card"><div class="body">Your cart is empty.</div></div>
      <div id="cartTableWrap" class="card hidden">
        <div class="body">
          <div class="row" style="justify-content:space-between">
            <div class="chip">All amounts in ₹ (INR)</div>
            <div class="row">
              <button id="clearCart" class="btn">Clear Cart</button>
              <button id="checkoutBtn" class="btn primary">Checkout</button>
            </div>
          </div>
        </div>
        <div class="body">
          <table id="cartTable">
            <thead>
              <tr>
                <th>Item</th>
                <th>Price</th>
                <th>Qty</th>
                <th>Total</th>
                <th></th>
              </tr>
            </thead>
            <tbody></tbody>
            <tfoot>
              <tr>
                <td colspan="3" style="text-align:right">Grand Total</td>
                <td id="grandTotal">₹0</td>
                <td></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </div>
    </section>

    <!-- ADMIN -->
    <section id="admin">
      <div class="space-between" style="margin-bottom:12px">
        <h2>Admin Dashboard</h2>
        <span class="badge">Manage catalogue</span>
      </div>
      <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(280px,1fr))">
        <div class="card">
          <div class="img black">ADD PRODUCT</div>
          <div class="body">
            <form id="addProductForm">
              <div>
                <label>Product Name</label>
                <input required name="name" placeholder="Eg. Cotton T‑Shirt" />
              </div>
              <div>
                <label>Price (₹)</label>
                <input required type="number" name="price" min="1" step="1" placeholder="Eg. 499" />
              </div>
              <div>
                <label>Image URL (optional)</label>
                <input name="image" placeholder="https://…" />
              </div>
              <button class="btn primary" type="submit">Add Product</button>
            </form>
          </div>
        </div>
        <div class="card">
          <div class="img white">INVENTORY</div>
          <div class="body">
            <div id="adminList" class="grid products"></div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <footer>
    © <span id="year"></span> Usharamadmart • Demo store for learning (HTML/CSS/JS)
  </footer>

  <script>
    // ===== Utilities =====
    const INR = new Intl.NumberFormat('en-IN', { style: 'currency', currency: 'INR', maximumFractionDigits: 0 });
    const $ = (sel, root=document) => root.querySelector(sel);
    const $$ = (sel, root=document) => Array.from(root.querySelectorAll(sel));
    const store = {
      get(k, fallback){
        try{ return JSON.parse(localStorage.getItem(k)) ?? fallback }catch{ return fallback }
      },
      set(k, v){ localStorage.setItem(k, JSON.stringify(v)); }
    };

    // ===== Data =====
    const DEFAULT_PRODUCTS = [
      {id: 'p1', name: 'Cotton T‑Shirt', price: 499, color:'white', image:''},
      {id: 'p2', name: 'Denim Jeans', price: 1199, color:'blue', image:''},
      {id: 'p3', name: 'Running Shoes', price: 2499, color:'black', image:''},
      {id: 'p4', name: 'Sports Water Bottle', price: 399, color:'red', image:''},
      {id: 'p5', name: 'Wireless Earbuds', price: 1999, color:'black', image:''},
      {id: 'p6', name: 'Backpack', price: 1399, color:'blue', image:''},
      {id: 'p7', name: 'Notebook Pack (5)', price: 299, color:'white', image:''},
      {id: 'p8', name: 'Smart Watch', price: 2999, color:'black', image:''},
    ];

    let state = {
      user: store.get('um:user', null), // {username, role}
      products: store.get('um:products', DEFAULT_PRODUCTS),
      cart: store.get('um:cart', {}), // {productId: qty}
      route: location.hash.slice(1) || 'login',
      search: '',
      sort: 'popular'
    };

    function save(){
      store.set('um:products', state.products);
      store.set('um:cart', state.cart);
      store.set('um:user', state.user);
      updateHeader();
    }

    // ===== Routing =====
    function setRoute(hash){
      state.route = hash.replace('#','') || 'login';
      $$('main section').forEach(sec => sec.classList.remove('active'));
      const target = document.getElementById(state.route) || document.getElementById('login');
      target.classList.add('active');
    }
    window.addEventListener('hashchange', ()=>setRoute(location.hash));

    // ===== Header / Auth =====
    function updateHeader(){
      const count = Object.values(state.cart).reduce((a,b)=>a+b,0);
      $('#cartCount').textContent = count;
      $('#year').textContent = new Date().getFullYear();
      const role = state.user?.role || 'Guest';
      $('#rolePill').textContent = role.charAt(0).toUpperCase()+role.slice(1);
      if(state.user){
        $('#loginLink').classList.add('hidden');
        $('#logoutBtn').classList.remove('hidden');
      } else {
        $('#loginLink').classList.remove('hidden');
        $('#logoutBtn').classList.add('hidden');
      }
      if(state.user?.role === 'admin') $('#adminLink').classList.remove('hidden');
      else $('#adminLink').classList.add('hidden');
    }

    $('#logoutBtn').addEventListener('click', ()=>{
      state.user = null; save();
      location.hash = '#login';
    });

    $('#loginForm').addEventListener('submit', (e)=>{
      e.preventDefault();
      const fd = new FormData(e.target);
      const username = fd.get('username').trim().toLowerCase();
      const password = fd.get('password');
      const role = fd.get('role');
      const okUser = (username==='user' && password==='user123' && role==='user');
      const okAdmin = (username==='admin' && password==='admin123' && role==='admin');
      if(okUser || okAdmin){
        state.user = { username, role };
        save();
        location.hash = role==='admin' ? '#admin' : '#shop';
      } else {
        alert('Invalid credentials. Try user/user123 or admin/admin123.');
      }
    });

    // ===== Shop rendering =====
    function renderShop(){
      const grid = $('#productGrid');
      grid.innerHTML = '';
      let list = [...state.products];
      const q = state.search.toLowerCase();
      if(q) list = list.filter(p => p.name.toLowerCase().includes(q));
      if(state.sort==='priceAsc') list.sort((a,b)=>a.price-b.price);
      if(state.sort==='priceDesc') list.sort((a,b)=>b.price-a.price);
      if(state.sort==='name') list.sort((a,b)=>a.name.localeCompare(b.name));

      if(!list.length){
        grid.innerHTML = '<div class="muted">No products match your search.</div>';
        return;
      }

      list.forEach(p=>{
        const card = document.createElement('div');
        card.className = 'card';
        const imgClass = ['red','blue','black','white'].includes(p.color) ? p.color : 'blue';
        const imgHTML = p.image ? `<img class="img" src="${p.image}" alt="${p.name}" style="object-fit:cover"/>` : `<div class="img ${imgClass}">${p.name.split(' ').map(w=>w[0]).join('').slice(0,3).toUpperCase()}</div>`;
        card.innerHTML = `
          ${imgHTML}
          <div class="body">
            <div class="space-between">
              <div>
                <div style="font-weight:700">${p.name}</div>
                <div class="muted">ID: ${p.id}</div>
              </div>
              <div class="price">${INR.format(p.price)}</div>
            </div>
            <div class="row" style="margin-top:10px;justify-content:space-between">
              <button class="btn" data-id="${p.id}" data-act="minus">−</button>
              <input class="qty" data-id="${p.id}" type="number" min="1" step="1" value="1"/>
              <button class="btn" data-id="${p.id}" data-act="plus">+</button>
              <button class="btn primary right" data-id="${p.id}" data-act="add">Add to Cart</button>
            </div>
          </div>`;
        grid.appendChild(card);
      });

      // Event delegation for qty and add buttons
      grid.onclick = (e)=>{
        const btn = e.target.closest('button');
        if(!btn) return;
        const id = btn.dataset.id; const act = btn.dataset.act;
        const qtyInput = grid.querySelector(`input.qty[data-id="${id}"]`);
        if(!qtyInput) return;
        let val = parseInt(qtyInput.value || '1', 10);
        if(act==='minus') val = Math.max(1, val-1);
        if(act==='plus') val = val+1;
        if(act==='add') addToCart(id, val);
        qtyInput.value = val;
      };
    }

    $('#searchBox').addEventListener('input', (e)=>{ state.search = e.target.value; renderShop(); });
    $('#sortBox').addEventListener('change', (e)=>{ state.sort = e.target.value; renderShop(); });

    function addToCart(id, qty=1){
      state.cart[id] = (state.cart[id]||0) + qty;
      save();
      renderCart();
      alert('Added to cart');
    }

    // ===== Cart rendering & calculations =====
    function renderCart(){
      const tbody = $('#cartTable tbody');
      tbody.innerHTML='';
      const ids = Object.keys(state.cart);
      const items = ids.map(id=>({ ...state.products.find(p=>p.id===id), qty: state.cart[id] }))
                      .filter(Boolean);
      const empty = items.length===0;
      $('#cartEmpty').classList.toggle('hidden', !empty);
      $('#cartTableWrap').classList.toggle('hidden', empty);
      let grand = 0;
      items.forEach(item=>{
        const row = document.createElement('tr');
        const total = item.price * item.qty;
        grand += total;
        row.innerHTML = `
          <td>
            <div style="font-weight:700">${item.name}</div>
            <div class="muted">${item.id}</div>
          </td>
          <td>${INR.format(item.price)}</td>
          <td>
            <input class="qty" type="number" min="1" step="1" value="${item.qty}" data-id="${item.id}" />
          </td>
          <td>${INR.format(total)}</td>
          <td><button class="btn" data-remove="${item.id}">Remove</button></td>
        `;
        tbody.appendChild(row);
      });
      $('#grandTotal').textContent = INR.format(grand);

      // qty change
      tbody.oninput = (e)=>{
        const input = e.target.closest('input.qty');
        if(!input) return;
        const id = input.dataset.id;
        const val = Math.max(1, parseInt(input.value||'1',10));
        input.value = val;
        state.cart[id] = val;
        save();
        renderCart();
      };
      // remove
      tbody.onclick = (e)=>{
        const btn = e.target.closest('button[data-remove]');
        if(!btn) return;
        const id = btn.dataset.remove;
        delete state.cart[id];
        save();
        renderCart();
      };
    }

    $('#clearCart').addEventListener('click', ()=>{
      if(confirm('Clear all items from cart?')){
        state.cart = {}; save(); renderCart();
      }
    });

    $('#checkoutBtn').addEventListener('click', ()=>{
      if(!Object.keys(state.cart).length){ alert('Your cart is empty.'); return; }
      alert('Checkout successful! (demo)');
      state.cart = {}; save(); renderCart();
    });

    // ===== Admin functions =====
    function renderAdminList(){
      const wrap = $('#adminList');
      wrap.innerHTML = '';
      state.products.forEach(p=>{
        const card = document.createElement('div');
        card.className = 'card';
        const imgClass = ['red','blue','black','white'].includes(p.color) ? p.color : 'blue';
        const imgHTML = p.image ? `<img class="img" src="${p.image}" alt="${p.name}" style="object-fit:cover"/>` : `<div class="img ${imgClass}">${p.name.split(' ').map(w=>w[0]).join('').slice(0,3).toUpperCase()}</div>`;
        card.innerHTML = `
          ${imgHTML}
          <div class="body">
            <div class="space-between">
              <div>
                <div style="font-weight:700">${p.name}</div>
                <div class="muted">ID: ${p.id}</div>
              </div>
              <div class="price">${INR.format(p.price)}</div>
            </div>
            <div class="row" style="margin-top:10px;justify-content:space-between">
              <button class="btn" data-edit="${p.id}">Edit</button>
              <button class="btn" data-del="${p.id}">Delete</button>
            </div>
          </div>`;
        wrap.appendChild(card);
      });
      wrap.onclick = (e)=>{
        const del = e.target.closest('button[data-del]');
        const edit = e.target.closest('button[data-edit]');
        if(del){
          const id = del.dataset.del;
          if(confirm('Delete this product?')){
            state.products = state.products.filter(p=>p.id!==id);
            delete state.cart[id];
            save(); renderShop(); renderAdminList(); renderCart();
          }
        } else if(edit){
          const id = edit.dataset.edit;
          const p = state.products.find(x=>x.id===id);
          const name = prompt('Product name:', p.name) || p.name;
          const price = parseInt(prompt('Price (₹):', p.price) || p.price, 10);
          const image = prompt('Image URL (optional):', p.image || '') || '';
          p.name = name; p.price = Math.max(1, price|0); p.image = image;
          save(); renderShop(); renderAdminList(); renderCart();
        }
      };
    }

    $('#addProductForm').addEventListener('submit', (e)=>{
      e.preventDefault();
      const fd = new FormData(e.target);
      const name = String(fd.get('name')).trim();
      const price = Math.max(1, parseInt(fd.get('price'),10));
      const image = String(fd.get('image')||'');
      const id = 'p' + Math.random().toString(36).slice(2,8);
      const color = ['red','blue','black','white'][Math.floor(Math.random()*4)];
      state.products.push({id,name,price,image,color});
      e.target.reset();
      save(); renderShop(); renderAdminList();
    });

    // ===== Init =====
    function init(){
      updateHeader();
      setRoute(location.hash);
      renderShop();
      renderCart();
      renderAdminList();
      // Auth guard for admin
      window.addEventListener('hashchange', ()=>{
        if(location.hash==="#admin" && state.user?.role!=="admin"){
          alert('Admins only. Please login as admin.');
          location.hash = '#login';
        }
        if(location.hash==="#shop" && !state.user){
          alert('Please login to continue.');
          location.hash = '#login';
        }
      });
    }

    init();
  </script>
</body>
</html>